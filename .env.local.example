# Copy to .env.local and fill in real values

# Supabase — from displaygg project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — create API key at resend.com
RESEND_API_KEY=re_xxxxx

# Vercel Blob — public URL of uploaded PDF
# Run: BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx node scripts/upload-pdf.mjs
BLOB_PDF_URL=https://public.blob.vercel-storage.com/ebooks/display-advertising-gone-bad.pdf
